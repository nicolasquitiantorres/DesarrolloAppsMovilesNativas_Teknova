<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="115dp"
            android:background="#111111"
            android:gravity="center_vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="38dp">

            <ImageView
                android:layout_width="164dp"
                android:layout_height="102dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_teknova" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/iconoPerfil"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/icono_usuario"/>

            <ImageView
                android:id="@+id/iconoCarrito"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/icono_carrito"
                android:layout_marginLeft="20dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/botonVolver"
            android:layout_width="120dp"
            android:layout_height="45dp"
            android:text="← Volver"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/boton_volver"
            android:layout_marginLeft="20dp"
            android:backgroundTint="@null"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#D9D9D9"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:padding="14dp"
            android:layout_marginTop="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EFEFEF"
                android:orientation="horizontal"
                android:padding="10dp"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/producto1_detalle"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginLeft="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nothing Phone 4a Pro"
                        android:textSize="15sp"
                        android:textColor="#000000"/>

                    <LinearLayout
                        android:layout_width="110dp"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:background="#9A72B2"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/botonMenos"
                            android:layout_width="36dp"
                            android:layout_height="match_parent"
                            android:text="&lt;"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textSize="20sp"/>

                        <TextView
                            android:id="@+id/textoCantidad"
                            android:layout_width="36dp"
                            android:layout_height="match_parent"
                            android:text="1"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:textSize="18sp"/>

                        <TextView
                            android:id="@+id/botonMas"
                            android:layout_width="36dp"
                            android:layout_height="match_parent"
                            android:text="&gt;"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textSize="20sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 2.500.000"
                            android:textColor="#7B5AA6"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/botonEliminar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗑"
                            android:textSize="22sp"
                            android:layout_marginLeft="120dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/textoSubtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtotal: $2.500.000"
                android:textSize="22sp"
                android:textColor="#7B5AA6"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Métodos de envío"
                android:textSize="18sp"
                android:textColor="#555555"
                android:layout_marginTop="18dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="#EFEFEF"
                android:gravity="center_vertical"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginTop="10dp">

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Código postal"
                    android:textSize="14sp"
                    android:background="#00000000"/>

                <Button
                    android:layout_width="95dp"
                    android:layout_height="38dp"
                    android:text="Calcular"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7B5AA6"/>

            </LinearLayout>

            <TextView
                android:id="@+id/textoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL: $2.518.000"
                android:textSize="26sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/botonIrPago"
            android:layout_width="220dp"
            android:layout_height="55dp"
            android:text="Iniciar compra"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B5AA6"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"/>

        <ImageView
            android:layout_width="220dp"
            android:layout_height="70dp"
            android:src="@drawable/metodos_pago"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="25dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp">

            <Button
                android:layout_width="110dp"
                android:layout_height="55dp"
                android:text="Calificar"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="@null"
                android:textColor="#000000"
                android:background="@drawable/boton_circular"/>

            <Button
                android:layout_width="110dp"
                android:layout_height="55dp"
                android:text="Contacto"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:backgroundTint="@null"
                android:background="@drawable/boton_circular"
                android:layout_marginLeft="8dp"/>

            <Button
                android:layout_width="110dp"
                android:layout_height="55dp"
                android:text="Denunciar"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"
                android:layout_marginLeft="8dp"/>

        </LinearLayout>
    </LinearLayout>

</ScrollView>