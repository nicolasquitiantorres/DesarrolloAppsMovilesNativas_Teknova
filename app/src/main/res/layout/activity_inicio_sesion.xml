<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/banner_teknova"/>

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#D9CFE3"
            android:padding="28dp"
            android:layout_marginTop="-6dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGIN"
                android:textStyle="bold"
                android:textSize="24sp"
                android:letterSpacing="0.2"
                android:textColor="#000000"
                android:layout_gravity="center"
                android:layout_marginBottom="28dp"/>

            <EditText
                android:id="@+id/campoUsuario"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="username"
                android:padding="14dp"
                android:background="@drawable/fondo_input"
                android:layout_marginBottom="18dp"/>

            <EditText
                android:id="@+id/campoPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="password"
                android:padding="14dp"
                android:background="@drawable/fondo_input"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/botonIngresar"
                android:layout_width="140dp"
                android:layout_height="50dp"
                android:text="LOGIN"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_gravity="center"
                android:backgroundTint="#E8E8E8"/>

            <TextView
                android:id="@+id/textoRecuperar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Olvidaste tu contraseña?"
                android:textColor="#9A72B2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Aún no tienes una cuenta? Regístrate"
            android:textSize="12sp"
            android:textColor="#444444"
            android:layout_marginTop="22dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:layout_marginTop="18dp">

            <Button
                android:id="@+id/botonAdmin"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="Admin"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#9A72B2"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"/>

            <Button
                android:id="@+id/botonVendedor"
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="Vendedor"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="@null"
                android:layout_marginLeft="10dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/botonBiometrico"
            android:layout_width="220dp"
            android:layout_height="55dp"
            android:text="Acceso Biométrico"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#9A72B2"
            android:background="@drawable/boton_circular"
            android:backgroundTint="@null"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="220dp"
            android:layout_marginTop="100dp"
            android:layout_marginBottom="0dp"
            android:src="@drawable/banner_teknova_abajo" />

    </LinearLayout>

</ScrollView>