<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="115dp"
            android:background="#111111"
            android:gravity="center_vertical"
            android:paddingLeft="18dp"
            android:paddingTop="38dp"
            android:paddingRight="18dp">

            <ImageView
                android:layout_width="164dp"
                android:layout_height="102dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_teknova" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/iconoPerfil"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/icono_usuario"/>

            <ImageView
                android:id="@+id/iconoCarrito"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/icono_carrito"
                android:layout_marginLeft="18dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/botonVolver"
            android:layout_width="120dp"
            android:layout_height="45dp"
            android:text="← Volver"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#9A72B2"
            android:background="@drawable/boton_circular"
            android:backgroundTint="@null"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASARELA DE PAGO"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#D9D9D9"
            android:layout_margin="20dp"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre completo"
                android:textColor="#555555"
                android:textSize="15sp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#EFEFEF"
                android:paddingLeft="14dp"
                android:hint="Ingresa tu nombre"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textColor="#555555"
                android:textSize="15sp"
                android:layout_marginTop="18dp"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#EFEFEF"
                android:paddingLeft="14dp"
                android:hint="Dirección de envío"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Método de pago"
                android:textColor="#555555"
                android:textSize="15sp"
                android:layout_marginTop="20dp"/>

            <RadioGroup
                android:id="@+id/grupoMetodoPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <RadioButton
                    android:id="@+id/radioTarjeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tarjeta"
                    android:textColor="#000000"/>

                <RadioButton
                    android:id="@+id/radioNequi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nequi"
                    android:textColor="#000000"/>

                <RadioButton
                    android:id="@+id/radioApplePay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apple Pay"
                    android:textColor="#000000"/>

            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutTarjeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Número de tarjeta"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#EFEFEF"
                    android:paddingLeft="14dp"
                    android:hint="XXXX XXXX XXXX XXXX"
                    android:layout_marginTop="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha"
                            android:textColor="#555555"
                            android:textSize="15sp"/>

                        <EditText
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="#EFEFEF"
                            android:paddingLeft="14dp"
                            android:hint="MM/AA"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CVV"
                            android:textColor="#555555"
                            android:textSize="15sp"/>

                        <EditText
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="#EFEFEF"
                            android:paddingLeft="14dp"
                            android:hint="123"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutNequi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Número Nequi"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#EFEFEF"
                    android:paddingLeft="14dp"
                    android:hint="300 123 4567"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutApplePay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compatible con Apple Wallet"
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:layout_marginTop="18dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/textoTotalPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL: $0"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="30dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/botonFinalizarCompra"
            android:layout_width="240dp"
            android:layout_height="55dp"
            android:text="Finalizar compra"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/boton_redondeado"
            android:backgroundTint="@null"
            android:layout_gravity="center"
            android:layout_marginBottom="50dp"/>

    </LinearLayout>

</ScrollView>