<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="115dp"
            android:background="#111111"
            android:gravity="center_vertical"
            android:paddingLeft="18dp"
            android:paddingTop="38dp"
            android:paddingRight="18dp">

            <ImageView
                android:layout_width="164dp"
                android:layout_height="102dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_teknova" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/iconoPerfil"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/icono_usuario"/>

            <ImageView
                android:id="@+id/iconoCarrito"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/icono_carrito"
                android:layout_marginLeft="18dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginLeft="20dp">

            <Button
                android:id="@+id/botonVolver"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="←"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFIL"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:letterSpacing="0.15"
                android:layout_marginLeft="10dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_perfil"
            android:layout_margin="25dp"
            android:padding="25dp"
            android:gravity="center">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_launcher_foreground"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre de Usuario"
                android:textSize="20sp"
                android:textColor="#000000"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="correo@email.com"
                android:textColor="#666666"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bogotá, Colombia"
                android:textColor="#666666"/>

            <Button
                android:layout_width="170dp"
                android:layout_height="50dp"
                android:text="Editar Perfil"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/boton_redondeado"
                android:backgroundTint="@null"
                android:layout_marginTop="20dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="25dp"
            android:layout_marginRight="25dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="IDIOMA          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="MONEDA          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"
                android:layout_marginTop="10dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="APARIENCIA          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="25dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="SEGURIDAD          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="DISPOSITIVOS          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"
                android:layout_marginTop="10dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="CONTRASEÑA          >"
                android:textAllCaps="false"
                android:textColor="#9A72B2"
                android:textStyle="bold"
                android:background="@drawable/boton_circular"
                android:backgroundTint="@null"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="50dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>